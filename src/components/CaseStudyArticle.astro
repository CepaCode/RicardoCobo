---
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import FinalCTA from "./FinalCTA.astro";

/**
 * CaseStudyArticle
 * ----------------
 * Magazine-style template for a client transformation case study.
 * All narratives, quotes and figures are realistic but FICTIONAL placeholders
 * for this private sales prototype — to be replaced with real testimonials.
 */
interface Stat {
  n: string;
  l: string;
}
interface StorySection {
  heading: string;
  paragraphs: string[];
}
interface Related {
  name: string;
  href: string;
}
interface Props {
  name: string;
  meta: string;
  title: string;
  intro: string;
  heroImage: ImageMetadata;
  beforeImage: ImageMetadata;
  afterImage: ImageMetadata;
  // Optional public URLs (e.g. /media/client-stories/carlos-cover.jpg).
  // When provided they take priority; if the file is missing the <img>
  // falls back to the bundled image above. Lets real photos be dropped in
  // without code changes.
  heroSrc?: string;
  beforeSrc?: string;
  afterSrc?: string;
  quote: string;
  stats: Stat[];
  story: StorySection[];
  lessons: string[];
  related: Related[];
  pageTitle: string;
  pageDescription: string;
}

const {
  name,
  meta,
  title,
  intro,
  heroImage,
  beforeImage,
  afterImage,
  heroSrc,
  beforeSrc,
  afterSrc,
  quote,
  stats,
  story,
  lessons,
  related,
  pageTitle,
  pageDescription,
} = Astro.props;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- ============================ HERO ============================ -->
  <article>
    <header class="relative isolate overflow-hidden bg-navy pt-32">
      <img
        src={heroSrc ?? heroImage.src}
        data-fallback={heroImage.src}
        onerror="this.onerror=null;this.src=this.dataset.fallback"
        alt={`${name} — transformación con Ricardo Cobo`}
        width={heroImage.width}
        height={heroImage.height}
        class="absolute inset-0 h-full w-full object-cover opacity-45"
        style="object-position: center 20%"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/70 to-navy/60"></div>

      <div class="relative mx-auto max-w-4xl px-5 py-24 text-center sm:px-8 lg:py-32">
        <a
          href="/resultados"
          class="eyebrow inline-flex items-center gap-2 text-brand-200 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <path d="M19 12H5M11 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Resultados
        </a>
        <p class="mt-6 text-sm font-semibold uppercase tracking-[0.22em] text-brand-200">{meta}</p>
        <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.0] tracking-tight text-white sm:text-5xl lg:text-6xl rc-rise">
          {title}
        </h1>
        <p class="mx-auto mt-7 max-w-2xl text-lg leading-relaxed text-white/75">
          {intro}
        </p>
      </div>
    </header>

    <!-- ======================= KEY STATS ======================= -->
    <section class="bg-brand">
      <div class="mx-auto max-w-7xl px-5 py-12 sm:px-8 lg:px-10">
        <dl class="grid grid-cols-1 gap-8 text-center sm:grid-cols-3">
          {
            stats.map((s) => (
              <div>
                <dt class="font-display text-4xl font-extrabold text-white sm:text-5xl">{s.n}</dt>
                <dd class="mt-2 text-sm text-brand-100">{s.l}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- ===================== BEFORE / AFTER ===================== -->
    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
        <div class="mb-10 text-center">
          <p class="eyebrow text-brand">La transformación</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-navy sm:text-4xl">Antes y después</h2>
          <p class="mx-auto mt-3 max-w-lg text-slate-blue">
            El mismo cuerpo, meses de constancia de diferencia. Así cambió la
            forma física de {name} a lo largo del programa.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <figure class="relative overflow-hidden rounded-3xl">
            <img
              src={beforeSrc ?? beforeImage.src}
              data-fallback={beforeImage.src}
              onerror="this.onerror=null;this.src=this.dataset.fallback"
              alt={`${name} antes del programa`}
              width={beforeImage.width}
              height={beforeImage.height}
              class="aspect-[3/4] w-full object-cover object-top"
              loading="lazy"
            />
            <figcaption class="absolute left-5 top-5 rounded-full bg-navy/70 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white ring-1 ring-white/15 backdrop-blur-sm">
              Antes
            </figcaption>
          </figure>
          <figure class="relative overflow-hidden rounded-3xl">
            <img
              src={afterSrc ?? afterImage.src}
              data-fallback={afterImage.src}
              onerror="this.onerror=null;this.src=this.dataset.fallback"
              alt={`${name} después del programa`}
              width={afterImage.width}
              height={afterImage.height}
              class="aspect-[3/4] w-full object-cover object-top"
              loading="lazy"
            />
            <figcaption class="absolute left-5 top-5 rounded-full bg-brand px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white ring-1 ring-white/15 backdrop-blur-sm">
              Después
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ====================== PULL QUOTE ====================== -->
    <section class="bg-mist">
      <div class="mx-auto max-w-4xl px-6 py-20 text-center sm:px-8 lg:py-28">
        <span class="font-display text-7xl font-bold leading-none text-brand/20" aria-hidden="true">“</span>
        <blockquote class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight text-navy text-balance sm:text-4xl">
          “{quote}”
        </blockquote>
        <p class="mt-6 text-sm font-semibold uppercase tracking-[0.2em] text-brand">{meta}</p>
      </div>
    </section>

    <!-- ======================== STORY ======================== -->
    <section class="bg-white">
      <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 lg:py-28">
        {
          story.map((s) => (
            <div class="mb-12 last:mb-0">
              <h2 class="font-display text-2xl font-bold text-navy sm:text-3xl">{s.heading}</h2>
              {s.paragraphs.map((p) => (
                <p class="mt-4 text-lg leading-relaxed text-slate-blue">{p}</p>
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <!-- ==================== LESSONS LEARNED ==================== -->
    <section class="bg-navy">
      <div class="mx-auto max-w-5xl px-5 py-20 sm:px-8 lg:py-28">
        <div class="max-w-2xl">
          <p class="eyebrow text-brand-200">Lo que aprendimos</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-white sm:text-4xl">
            Las claves de este cambio
          </h2>
        </div>
        <ul class="mt-10 grid gap-5 sm:grid-cols-2">
          {
            lessons.map((l, i) => (
              <li class="flex gap-4 rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
                <span class="font-display text-2xl font-bold text-brand-200">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <p class="text-white/80">{l}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- ====================== RELATED ====================== -->
    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 lg:px-10">
        <div class="flex flex-col gap-6 border-t border-haze pt-12 sm:flex-row sm:items-center sm:justify-between">
          <h2 class="font-display text-2xl font-bold text-navy">Otras historias</h2>
          <div class="flex flex-wrap gap-3">
            {
              related.map((r) => (
                <a
                  href={r.href}
                  class="inline-flex items-center gap-2 rounded-full border border-steel px-5 py-2.5 text-sm font-semibold text-navy transition-all hover:border-brand hover:text-brand"
                >
                  {r.name}
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </article>

  <FinalCTA />
</BaseLayout>
