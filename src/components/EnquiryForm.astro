---
/**
 * EnquiryForm
 * -----------
 * Conversion-focused enquiry form (prototype — no backend connected).
 * Fields: Nombre, Email, Teléfono, Objetivo principal, Mensaje.
 *
 * 👉 TODO (producción): conectar a un endpoint / servicio de email
 *    (Formspree, Resend, Power Automate, etc.) en el atributo `action`.
 */
const objetivos = [
  "Perder peso y grasa corporal",
  "Ganar fuerza y tono muscular",
  "Recuperar el hábito de entrenar",
  "Mejorar energía y salud general",
  "Prepararme para un objetivo concreto",
  "Aún no lo tengo claro",
];
---

<form
  id="enquiry-form"
  class="grid gap-5"
  novalidate
>
  <div class="grid gap-5 sm:grid-cols-2">
    <div class="flex flex-col gap-2">
      <label for="nombre" class="text-sm font-semibold text-navy">Nombre</label>
      <input
        id="nombre"
        name="nombre"
        type="text"
        autocomplete="name"
        required
        placeholder="Tu nombre"
        class="rounded-xl border border-steel bg-white px-4 py-3.5 text-navy outline-none transition-all placeholder:text-slate-blue/60 focus:border-brand focus:ring-4 focus:ring-brand/10"
      />
    </div>

    <div class="flex flex-col gap-2">
      <label for="email" class="text-sm font-semibold text-navy">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        required
        placeholder="tu@email.com"
        class="rounded-xl border border-steel bg-white px-4 py-3.5 text-navy outline-none transition-all placeholder:text-slate-blue/60 focus:border-brand focus:ring-4 focus:ring-brand/10"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div class="flex flex-col gap-2">
      <label for="telefono" class="text-sm font-semibold text-navy">Teléfono</label>
      <input
        id="telefono"
        name="telefono"
        type="tel"
        autocomplete="tel"
        placeholder="+34 600 000 000"
        class="rounded-xl border border-steel bg-white px-4 py-3.5 text-navy outline-none transition-all placeholder:text-slate-blue/60 focus:border-brand focus:ring-4 focus:ring-brand/10"
      />
    </div>

    <div class="flex flex-col gap-2">
      <label for="objetivo" class="text-sm font-semibold text-navy">Objetivo principal</label>
      <select
        id="objetivo"
        name="objetivo"
        class="rounded-xl border border-steel bg-white px-4 py-3.5 text-navy outline-none transition-all focus:border-brand focus:ring-4 focus:ring-brand/10"
      >
        {objetivos.map((o) => <option value={o}>{o}</option>)}
      </select>
    </div>
  </div>

  <div class="flex flex-col gap-2">
    <label for="mensaje" class="text-sm font-semibold text-navy">Mensaje</label>
    <textarea
      id="mensaje"
      name="mensaje"
      rows="4"
      placeholder="Cuéntame brevemente tu situación y qué te gustaría conseguir."
      class="resize-none rounded-xl border border-steel bg-white px-4 py-3.5 text-navy outline-none transition-all placeholder:text-slate-blue/60 focus:border-brand focus:ring-4 focus:ring-brand/10"
    ></textarea>
  </div>

  <div class="mt-2 flex flex-col gap-3 sm:flex-row">
    <button
      type="submit"
      class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-brand px-7 py-4 text-base font-semibold text-white shadow-lg shadow-brand/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-700 hover:shadow-xl"
    >
      Solicitar valoración
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <!-- TODO: reemplazar el número por el WhatsApp real de Ricardo -->
    <a
      href="https://wa.me/000000000000?text=Hola%20Ricardo%2C%20me%20gustar%C3%ADa%20reservar%20una%20valoraci%C3%B3n."
      class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-brand px-7 py-4 text-base font-semibold text-brand transition-all duration-300 hover:bg-brand hover:text-white"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12.04 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.75.46 3.45 1.32 4.95L2 22l5.3-1.39c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.9-4.44 9.9-9.9S17.5 2 12.04 2zm0 18.06c-1.48 0-2.93-.4-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.16 8.16 0 01-1.26-4.34c0-4.54 3.7-8.23 8.24-8.23s8.23 3.69 8.23 8.23-3.69 8.2-8.23 8.2zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.15.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z" />
      </svg>
      Contactar por WhatsApp
    </a>
  </div>

  <p class="text-xs leading-relaxed text-slate-blue">
    Tus datos solo se usarán para responderte sobre la valoración. Sin compromiso.
  </p>

  <!-- Prototype confirmation message -->
  <p
    id="enquiry-success"
    role="status"
    class="hidden rounded-xl bg-brand-50 px-4 py-3 text-sm font-medium text-brand ring-1 ring-brand/15"
  >
    ¡Gracias! Hemos recibido tu solicitud. Ricardo te contactará muy pronto.
    <span class="text-slate-blue">(Demostración — el formulario aún no está conectado.)</span>
  </p>
</form>

<script is:inline>
  (function () {
    const form = document.getElementById("enquiry-form");
    const success = document.getElementById("enquiry-success");
    if (!form) return;
    form.addEventListener("submit", function (e) {
      // Prototype: prevent real submission and show confirmation.
      e.preventDefault();
      const nombre = form.querySelector("#nombre");
      const email = form.querySelector("#email");
      if (!nombre.value.trim() || !email.value.trim()) {
        form.reportValidity?.();
        return;
      }
      success?.classList.remove("hidden");
      form.reset();
      success?.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  })();
</script>
