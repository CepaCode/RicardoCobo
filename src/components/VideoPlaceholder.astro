---
import type { ImageMetadata } from "astro";

interface Props {
  videoPath: string;
  fallbackImage: ImageMetadata;
  alt: string;
  label?: string;
  showOverlayInfo?: boolean;
  class?: string;
  ratio?: string;
  rounded?: string;
  overlay?: "light" | "dark";
}

const {
  videoPath,
  fallbackImage,
  alt,
  label,
  showOverlayInfo = false,
  class: extra = "",
  ratio = "aspect-[16/9]",
  rounded = "rounded-2xl",
  overlay = "dark",
} = Astro.props;

const resolvedVideoPath = videoPath;
const overlayLabel = label ?? resolvedVideoPath;

const overlayClass =
  overlay === "dark"
    ? "from-navy/85 via-navy/35 to-brand/30"
    : "from-brand-800/70 via-brand/20 to-transparent";
---

<div
  class={`group relative isolate w-full overflow-hidden ${ratio} ${rounded} ${extra}`}
  data-video-placeholder
  data-state="loading"
>
  <img
    src={fallbackImage.src}
    alt={alt}
    width={fallbackImage.width}
    height={fallbackImage.height}
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-105"
    loading="lazy"
  />

  <video
    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700 data-[ready]:opacity-100"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={fallbackImage.src}
    aria-label={alt}
  >
    <source src={resolvedVideoPath} type="video/mp4" />
  </video>

  <div
    class={`absolute inset-0 bg-gradient-to-t transition-opacity duration-700 group-data-[state=playing]:opacity-40 ${overlayClass}`}
  ></div>

  <div class="absolute inset-0 bg-brand/15 mix-blend-multiply"></div>

  <div class="absolute inset-0 flex items-center justify-center transition-opacity duration-500 group-data-[state=playing]:opacity-0">
    <span
      class="flex h-16 w-16 items-center justify-center rounded-full bg-white/15 ring-1 ring-white/40 backdrop-blur-md transition-all duration-500 group-hover:scale-110 group-hover:bg-white/25 sm:h-20 sm:w-20"
    >
      <svg class="ml-1 h-7 w-7 text-white sm:h-8 sm:w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </div>

  {showOverlayInfo && (
    <>
      <div class="absolute left-4 top-4 transition-opacity duration-500 group-data-[state=playing]:opacity-60 sm:left-5 sm:top-5">
        <span
          class="inline-flex items-center gap-2 rounded-full bg-navy/70 px-3.5 py-1.5 text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-white ring-1 ring-white/15 backdrop-blur-sm"
        >
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-brand-300"></span>
          Video pendiente
        </span>
      </div>

      <div class="absolute bottom-4 left-4 right-4 transition-opacity duration-500 group-data-[state=playing]:opacity-60 sm:bottom-5 sm:left-5">
        <code
          class="inline-block max-w-full truncate rounded-lg bg-navy/65 px-3 py-1.5 font-mono text-xs text-brand-100 ring-1 ring-white/10 backdrop-blur-sm"
        >
          {overlayLabel}
        </code>
      </div>
    </>
  )}
</div>

<script>
  const setup = (root: HTMLElement) => {
    const video = root.querySelector<HTMLVideoElement>("video");
    if (!video) return;

    const img = root.querySelector<HTMLImageElement>("img");
    const delay = Number(root.dataset.fallbackDelay ?? 0);

    const showImage = () => {
      if (img) img.dataset.shown = "";
    };

    const reveal = () => {
      root.dataset.state = "playing";
      video.dataset.ready = "";
    };

    const fail = () => {
      root.dataset.state = "missing";
      delete video.dataset.ready;
      showImage();
    };

    if (delay > 0) {
      window.setTimeout(() => {
        if (root.dataset.state !== "playing") showImage();
      }, delay);
    } else {
      showImage();
    }

    if (video.readyState >= 2) reveal();

    video.addEventListener("playing", reveal, { once: true });
    video.addEventListener("loadeddata", () => {
      if (video.readyState >= 2) reveal();
    });
    video.addEventListener("error", fail);
    video.querySelector("source")?.addEventListener("error", fail);

    const tryPlay = video.play();
    if (tryPlay && typeof tryPlay.catch === "function") {
      tryPlay.catch(() => {});
    }
  };

  document
    .querySelectorAll<HTMLElement>("[data-video-placeholder]")
    .forEach(setup);
</script>